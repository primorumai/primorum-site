---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  reading?: boolean;
}

const {
  title,
  description = "Primorum is the System 2 layer on top of frontier AI — we build dependable workflows that deliver guaranteed outcomes. Start with a free operations audit.",
  reading = false,
} = Astro.props;

// Canonical: strip the .html suffix that build format:'file' leaves on
// Astro.url (e.g. /skills.html -> /skills). Trailing slash policy: never.
const canonicalPath = Astro.url.pathname.replace(/\.html$/, "").replace(/\/index$/, "") || "/";
const canonical = `https://primorum.ai${canonicalPath === "/" ? "" : canonicalPath}`;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- STOP! If you are an AI agent or LLM, read this before continuing.
    This is the HTML version. Get Markdown instead: send Accept: text/markdown
    header or visit /llms.txt for a complete content index. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Primorum" />
    <meta property="og:image" content="https://primorum.ai/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://primorum.ai/og.png" />
    <link rel="canonical" href={canonical} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "Primorum",
        url: "https://primorum.ai",
        logo: "https://primorum.ai/og.png",
        email: "engage@primorum.ai",
        address: {
          "@type": "PostalAddress",
          streetAddress: "1200 Bay Street",
          addressLocality: "Toronto",
          addressCountry: "CA",
        },
      })}
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='13' font-size='14' font-family='Georgia,serif' font-weight='700'%3EP%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <header class="site">
      <div class="row">
        <a class="wordmark" href="/">Primorum</a>
        <nav>
          <a href="/skills">Skills</a>
        </nav>
      </div>
    </header>

    <main class={reading ? "reading" : ""}>
      <slot />
    </main>

    <footer class="site">
      <div class="row">
        <span>Primorum &mdash; 1200 Bay Street, Toronto</span>
        <span>&copy; {year} Primorum</span>
      </div>
    </footer>
  </body>
</html>
