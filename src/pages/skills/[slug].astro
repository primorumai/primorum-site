---
import Base from "../../layouts/Base.astro";
import skills from "../../data/skills.json";
import { installInstructions, installPrompt } from "../../lib/install.js";

export function getStaticPaths() {
  return skills.map((s) => ({ params: { slug: s.slug }, props: { skill: s } }));
}

const { skill } = Astro.props;
const install = installInstructions(skill);
const prompt = installPrompt(skill);

const title = `${skill.name} — Agent Skill${skill.official ? " (Official)" : ""} | Primorum Skills Directory`;
const description = `${skill.summary} By ${skill.author}. ${skill.category} skill for Claude Code and compatible AI agents — source on GitHub.`;

const related = skills
  .filter((s) => s.slug !== skill.slug && s.category === skill.category)
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: skill.name,
  description: skill.summary,
  codeRepository: skill.repo,
  author: { "@type": skill.official ? "Organization" : "Person", name: skill.author },
  programmingLanguage: "Markdown",
  applicationCategory: "DeveloperApplication",
  keywords: skill.tags.join(", "),
  url: `https://primorum.ai/skills/${skill.slug}`,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Primorum", item: "https://primorum.ai" },
    { "@type": "ListItem", position: 2, name: "Skills", item: "https://primorum.ai/skills" },
    { "@type": "ListItem", position: 3, name: skill.name, item: `https://primorum.ai/skills/${skill.slug}` },
  ],
};

const fmtStars = (n) =>
  n >= 1000 ? `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k` : String(n);
---

<Base title={title} description={description} reading={true}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <p class="eyebrow">
    <a href="/skills" class="crumb">Skills Directory</a> / {skill.category}
  </p>

  <h1>{skill.name}</h1>

  <dl class="contact-grid skill-facts">
    <dt>Author</dt>
    <dd>{skill.author}{skill.official && " — official vendor skill"}</dd>
    <dt>Category</dt>
    <dd>{skill.category}</dd>
    <dt>Stars</dt>
    <dd>★ {fmtStars(skill.stars)}</dd>
    <dt>Source</dt>
    <dd>
      <a href={skill.repo} target="_blank" rel="noopener">{skill.repo.replace("https://github.com/", "github.com/")}</a>
    </dd>
    <dt>Tags</dt>
    <dd class="mono skill-tags">{skill.tags.join(" · ")}</dd>
  </dl>

  <hr class="divider" />

  <p>{skill.description}</p>

  <p class="cta-block">
    <a class="cta" href={skill.repo} target="_blank" rel="noopener">View on GitHub</a>
  </p>

  <h2 id="install">How to load this skill</h2>

  <div class="prompt-box">
    <p class="install-label mono">Fastest: copy this prompt into your AI agent</p>
    <pre class="install-prompt" id="install-prompt"><code>{prompt}</code></pre>
    <button class="copy-prompt mono" id="copy-prompt-btn" type="button">
      Copy install prompt
    </button>
  </div>

  <p>{install.note}</p>
  <ol class="install-steps">
    {
      install.steps.map((st) => (
        <li>
          <span class="install-label mono">{st.label}</span>
          <pre class="install-cmd"><code>{st.command}</code></pre>
        </li>
      ))
    }
  </ol>
  <p class="cta-note">
    For AI agents: this entry is also available as JSON at
    <a href="/skills/skills.json"><code>/skills/skills.json</code></a> — the
    <code>install.steps</code> field contains these commands. See the
    <a href="/skills#for-agents">agent instructions</a> on the directory index.
  </p>

  {
    related.length > 0 && (
      <>
        <hr class="divider" />
        <h2>Related in {skill.category}</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={`/skills/${r.slug}`}>{r.name}</a> — {r.summary}
            </li>
          ))}
        </ul>
      </>
    )
  }

  <p class="mono back-link"><a href="/skills">&larr; All skills</a></p>
</Base>

<style>
  .crumb {
    text-decoration: none;
  }
  .skill-facts {
    margin-top: 1.5rem;
  }
  .skill-tags {
    text-transform: none;
    letter-spacing: 0.02em;
  }
  .back-link {
    margin-top: 3rem;
  }
  .install-steps {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem;
  }
  .install-steps li {
    border-top: 1px solid var(--rule);
    padding: 1rem 0;
  }
  .install-label {
    color: var(--muted);
    display: block;
    margin-bottom: 0.4rem;
  }
  .install-cmd {
    margin: 0;
    padding: 0.6rem 0.8rem;
    background: rgba(0, 0, 0, 0.045);
    overflow-x: auto;
    font-size: 0.82rem;
  }
  .install-cmd code {
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
  }
  .prompt-box {
    border: 1px solid var(--rule);
    padding: 1rem 1.2rem 1.2rem;
    margin: 1.25rem 0 1.75rem;
  }
  .install-prompt {
    margin: 0 0 0.9rem;
    padding: 0.6rem 0.8rem;
    background: rgba(0, 0, 0, 0.045);
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.5;
    white-space: pre-wrap;
    max-height: 16rem;
    overflow-y: auto;
  }
  .install-prompt code {
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
  }
  .copy-prompt {
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
  }
  .copy-prompt:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .copy-prompt.copied {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
</style>

<script>
  const btn = document.getElementById("copy-prompt-btn");
  const pre = document.getElementById("install-prompt");

  function legacyCopy(text: string): boolean {
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    document.body.appendChild(ta);
    ta.select();
    let ok = false;
    try {
      ok = document.execCommand("copy");
    } catch {}
    ta.remove();
    return ok;
  }

  btn?.addEventListener("click", async () => {
    const text = pre?.textContent?.trim();
    if (!text) return;
    let ok = false;
    try {
      await navigator.clipboard.writeText(text);
      ok = true;
    } catch {
      ok = legacyCopy(text);
    }
    const prev = btn.textContent;
    btn.textContent = ok ? "Copied — paste into your AI" : "Copy failed — select the text above";
    btn.classList.toggle("copied", ok);
    setTimeout(() => {
      btn.textContent = prev;
      btn.classList.remove("copied");
    }, 2000);
  });
</script>

<script src="../../scripts/webmcp-skills.js"></script>
