---
import Base from "../../layouts/Base.astro";
import skills from "../../data/skills.json";

export function getStaticPaths() {
  return skills.map((s) => ({ params: { slug: s.slug }, props: { skill: s } }));
}

const { skill } = Astro.props;

const title = `${skill.name} — Agent Skill${skill.official ? " (Official)" : ""} | Primorum Skills Directory`;
const description = `${skill.summary} By ${skill.author}. ${skill.category} skill for Claude Code and compatible AI agents — source on GitHub.`;

const related = skills
  .filter((s) => s.slug !== skill.slug && s.category === skill.category)
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: skill.name,
  description: skill.summary,
  codeRepository: skill.repo,
  author: { "@type": skill.official ? "Organization" : "Person", name: skill.author },
  programmingLanguage: "Markdown",
  applicationCategory: "DeveloperApplication",
  keywords: skill.tags.join(", "),
  url: `https://primorum.ai/skills/${skill.slug}`,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Primorum", item: "https://primorum.ai" },
    { "@type": "ListItem", position: 2, name: "Skills", item: "https://primorum.ai/skills" },
    { "@type": "ListItem", position: 3, name: skill.name, item: `https://primorum.ai/skills/${skill.slug}` },
  ],
};

const fmtStars = (n) =>
  n >= 1000 ? `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k` : String(n);
---

<Base title={title} description={description} reading={true}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <p class="eyebrow">
    <a href="/skills" class="crumb">Skills Directory</a> / {skill.category}
  </p>

  <h1>{skill.name}</h1>

  <dl class="contact-grid skill-facts">
    <dt>Author</dt>
    <dd>{skill.author}{skill.official && " — official vendor skill"}</dd>
    <dt>Category</dt>
    <dd>{skill.category}</dd>
    <dt>Stars</dt>
    <dd>★ {fmtStars(skill.stars)}</dd>
    <dt>Source</dt>
    <dd>
      <a href={skill.repo} target="_blank" rel="noopener">{skill.repo.replace("https://github.com/", "github.com/")}</a>
    </dd>
    <dt>Tags</dt>
    <dd class="mono skill-tags">{skill.tags.join(" · ")}</dd>
  </dl>

  <hr class="divider" />

  <p>{skill.description}</p>

  <p class="cta-block">
    <a class="cta" href={skill.repo} target="_blank" rel="noopener">View on GitHub</a>
    <span class="cta-note">
      Install per the repo's instructions — most skills drop into
      <code>~/.claude/skills/</code> or install as a Claude Code plugin.
    </span>
  </p>

  {
    related.length > 0 && (
      <>
        <hr class="divider" />
        <h2>Related in {skill.category}</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={`/skills/${r.slug}`}>{r.name}</a> — {r.summary}
            </li>
          ))}
        </ul>
      </>
    )
  }

  <p class="mono back-link"><a href="/skills">&larr; All skills</a></p>
</Base>

<style>
  .crumb {
    text-decoration: none;
  }
  .skill-facts {
    margin-top: 1.5rem;
  }
  .skill-tags {
    text-transform: none;
    letter-spacing: 0.02em;
  }
  .back-link {
    margin-top: 3rem;
  }
</style>
