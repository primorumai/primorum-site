---
import Base from "../../layouts/Base.astro";
import skills from "../../data/skills.json";

const sorted = [...skills].sort((a, b) => b.stars - a.stars);
const categories = [...new Set(skills.map((s) => s.category))].sort();

const title = "Agent Skills Directory — Curated Claude Code & AI Agent Skills | Primorum";
const description =
  "A curated directory of the best agent skills for Claude Code, Codex, Cursor, and other AI coding agents. Official vendor skills, development workflows, and directories — every entry links to its GitHub source.";

const fmtStars = (n) =>
  n >= 1000 ? `${(n / 1000).toFixed(n >= 10000 ? 0 : 1)}k` : String(n);

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Agent Skills Directory",
  description,
  url: "https://primorum.ai/skills",
  numberOfItems: sorted.length,
  itemListElement: sorted.map((s, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `https://primorum.ai/skills/${s.slug}`,
    name: s.name,
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Primorum", item: "https://primorum.ai" },
    { "@type": "ListItem", position: 2, name: "Skills", item: "https://primorum.ai/skills" },
  ],
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <p class="eyebrow">Directory</p>
  <h1>Agent Skills</h1>
  <p class="lede">
    A curated directory of skills for AI coding agents — Claude Code, Codex,
    Cursor, Gemini CLI, and anything else that reads
    <code>SKILL.md</code>. Official vendor skills, battle-tested workflows, and
    the directories worth knowing. Every entry links to its source on GitHub.
  </p>

  <div class="skills-controls">
    <input
      type="search"
      id="skill-search"
      placeholder="Search skills… (name, author, tag)"
      aria-label="Search skills"
    />
    <div class="skills-filters" role="group" aria-label="Filter by category">
      <button class="filter-btn active" data-cat="all">All</button>
      {categories.map((c) => <button class="filter-btn" data-cat={c}>{c}</button>)}
    </div>
  </div>

  <p class="skills-count mono" id="skills-count">{sorted.length} skills</p>

  <ul class="skills-list" id="skills-list">
    {
      sorted.map((s) => (
        <li
          class="skill-card"
          data-cat={s.category}
          data-search={`${s.name} ${s.author} ${s.category} ${s.tags.join(" ")} ${s.summary}`.toLowerCase()}
        >
          <div class="skill-head">
            <a class="skill-name" href={`/skills/${s.slug}`}>
              {s.name}
            </a>
            <span class="skill-stars mono">★ {fmtStars(s.stars)}</span>
          </div>
          <p class="skill-meta mono">
            {s.author}
            {s.official && <span class="badge-official">Official</span>}
            <span class="skill-cat">{s.category}</span>
          </p>
          <p class="skill-summary">{s.summary}</p>
          <p class="skill-links mono">
            <a href={`/skills/${s.slug}`}>Details</a>
            <a href={s.repo} target="_blank" rel="noopener">
              GitHub &nearr;
            </a>
          </p>
        </li>
      ))
    }
  </ul>

  <hr class="divider" />

  <h2>What are agent skills?</h2>
  <p>
    Agent skills are folders containing a <code>SKILL.md</code> file — YAML
    frontmatter plus markdown instructions — that teach an AI coding agent a
    workflow, domain, or tool it doesn't know out of the box. The format was
    introduced by Anthropic for Claude Code and is now an open standard
    (<a href="https://agentskills.io" target="_blank" rel="noopener">agentskills.io</a>)
    supported by a growing set of agents. The agent loads a skill only when
    relevant, so skills add capability without permanent context cost.
  </p>
  <p>
    This directory tracks the collections we actually rate: official vendor
    skills written by platform teams, workflow libraries proven in daily use,
    and the curated lists that separate signal from bulk-generated noise.
  </p>

  <hr class="divider" />

  <h2 id="for-agents">For AI agents: how to use this directory</h2>
  <p>
    <strong>Machine-readable index:</strong> fetch
    <a href="/skills/skills.json"><code>https://primorum.ai/skills/skills.json</code></a>
    for all entries as JSON — name, category, tags, GitHub repo, and
    copy-paste install instructions per skill. CORS-enabled, no auth.
  </p>
  <p>
    <strong>Loading a skill for your user:</strong> skills are folders
    containing a <code>SKILL.md</code> file. The general pattern:
  </p>
  <ol>
    <li>
      Pick an entry, fetch its <code>install</code> steps from
      <code>/skills/skills.json</code> (or the per-skill page).
    </li>
    <li>
      For Claude Code plugin marketplaces: run
      <code>/plugin marketplace add &lt;owner/repo&gt;</code>, then install
      plugins from it.
    </li>
    <li>
      For plain skill repos: <code>git clone</code> the repo and copy the
      skill folder into <code>~/.claude/skills/</code> (personal) or
      <code>.claude/skills/</code> (project) — or your agent's equivalent
      SKILL.md directory.
    </li>
    <li>
      To read a skill without installing:
      <code>curl -sL https://raw.githubusercontent.com/&lt;owner/repo&gt;/main/&lt;skill&gt;/SKILL.md</code>
    </li>
  </ol>
  <p>
    <strong>In-browser agents (WebMCP):</strong> this page registers three
    read-only tools via <code>document.modelContext</code> /
    <code>navigator.modelContext</code> when available —
    <code>search_skills</code>, <code>get_skill</code>, and
    <code>get_install_instructions</code>. The same tools are exposed on
    <code>window.__skillsDirectoryTools</code> for script-capable agents in
    browsers without native WebMCP support.
  </p>
</Base>

<script src="../../scripts/webmcp-skills.js"></script>

<style>
  .skills-controls {
    margin: 2rem 0 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  #skill-search {
    font-family: inherit;
    font-size: 1rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink);
    max-width: 28rem;
    width: 100%;
  }
  #skill-search:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }
  .skills-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .filter-btn {
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
  }
  .filter-btn.active {
    background: var(--ink);
    color: var(--bg);
  }
  .filter-btn:hover:not(.active) {
    border-color: var(--accent);
    color: var(--accent);
  }
  .skills-count {
    color: var(--muted);
    margin: 1.5rem 0 0;
  }
  .skills-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    gap: 0;
  }
  .skill-card {
    border-top: 1px solid var(--rule);
    padding: 1.5rem 0;
  }
  .skill-card.hidden {
    display: none;
  }
  .skill-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .skill-name {
    font-size: 1.2rem;
    font-weight: 600;
    text-decoration: none;
  }
  .skill-name:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .skill-stars {
    color: var(--muted);
    white-space: nowrap;
  }
  .skill-meta {
    color: var(--muted);
    margin: 0.35rem 0 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .badge-official {
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.1rem 0.45rem;
    font-size: 0.65rem;
  }
  .skill-cat {
    color: var(--muted);
  }
  .skill-summary {
    margin: 0 0 0.75rem;
    max-width: 44rem;
  }
  .skill-links {
    display: flex;
    gap: 1.5rem;
    margin: 0;
  }
</style>

<script>
  const search = document.getElementById("skill-search") as HTMLInputElement;
  const count = document.getElementById("skills-count")!;
  const cards = [...document.querySelectorAll<HTMLElement>(".skill-card")];
  const btns = [...document.querySelectorAll<HTMLElement>(".filter-btn")];
  let activeCat = "all";

  function apply() {
    const q = search.value.trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const matchCat = activeCat === "all" || card.dataset.cat === activeCat;
      const matchQ = !q || (card.dataset.search || "").includes(q);
      const show = matchCat && matchQ;
      card.classList.toggle("hidden", !show);
      if (show) visible++;
    }
    count.textContent = `${visible} skill${visible === 1 ? "" : "s"}`;
  }

  search.addEventListener("input", apply);
  for (const btn of btns) {
    btn.addEventListener("click", () => {
      btns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeCat = btn.dataset.cat || "all";
      apply();
    });
  }
</script>
