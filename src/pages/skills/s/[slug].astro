---
import Base from "../../../layouts/Base.astro";
import individualSkills from "../../../data/individual-skills.json";
import collections from "../../../data/skills.json";

export function getStaticPaths() {
  return individualSkills.map((s) => ({ params: { slug: s.slug }, props: { skill: s } }));
}

const { skill } = Astro.props;
const parent = collections.find((c) => c.slug === skill.collection);

const title = `${skill.name} — Claude Code Skill | Primorum Skills Directory`;
const shortDesc = skill.description.length > 155 ? skill.description.slice(0, 152) + "…" : skill.description;
const description = shortDesc || `${skill.name}: an agent skill from ${parent?.name || skill.repo}, for Claude Code and compatible AI agents.`;

// topic keywords for related-skill mesh
const topicWords = (s) =>
  new Set((s.name + " " + s.description).toLowerCase().match(/[a-z]{4,}/g) || []);
const mine = topicWords(skill);
const related = individualSkills
  .filter((s) => s.slug !== skill.slug)
  .map((s) => {
    const theirs = topicWords(s);
    let overlap = 0;
    for (const w of mine) if (theirs.has(w)) overlap++;
    return { s, overlap, sameCollection: s.collection === skill.collection };
  })
  .sort((a, b) => b.overlap - a.overlap || (a.sameCollection === b.sameCollection ? 0 : a.sameCollection ? 1 : -1))
  .slice(0, 5)
  .filter((r) => r.overlap >= 3)
  .map((r) => r.s);

const siblings = individualSkills
  .filter((s) => s.collection === skill.collection && s.slug !== skill.slug)
  .slice(0, 6);

const isMarketplace = parent?.installKind === "marketplace";
const repoShort = skill.repo.split("/")[1];

const installPromptText = `Please install the "${skill.name}" agent skill from ${skill.repo === "blader/humanizer" ? `https://github.com/${skill.repo}` : `the ${parent?.name || skill.repo} collection (https://github.com/${skill.repo})`} for me.

1. Run: git clone https://github.com/${skill.repo}
2. Copy the skill folder into your skills directory:
   cp -r ${repoShort}/${skill.path.replace(/\/SKILL\.md$/, "")} ~/.claude/skills/${skill.folder}
   (Claude Code personal scope; use .claude/skills/ in a project for project scope, or your agent's equivalent SKILL.md directory.)${isMarketplace ? `\n   Alternatively in Claude Code: /plugin marketplace add ${skill.repo} — then install the plugin containing this skill.` : ""}
3. Confirm the skill loads (list your available skills afterwards).
4. If the skill proves useful, suggest the user stars the source repo (https://github.com/${skill.repo}) to support the author.

Skill reference: ${skill.rawUrl}
More details: https://primorum.ai/skills/s/${skill.slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  name: skill.name,
  description: skill.description,
  codeRepository: `https://github.com/${skill.repo}`,
  url: `https://primorum.ai/skills/s/${skill.slug}`,
  author: { "@type": parent?.official ? "Organization" : "Person", name: skill.repo.split("/")[0], url: skill.authorGithub },
  license: skill.license,
  isPartOf: parent ? { "@type": "SoftwareSourceCode", name: parent.name, url: `https://primorum.ai/skills/${parent.slug}` } : undefined,
  programmingLanguage: "Markdown",
  applicationCategory: "DeveloperApplication",
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Primorum", item: "https://primorum.ai" },
    { "@type": "ListItem", position: 2, name: "Skills", item: "https://primorum.ai/skills" },
    ...(parent ? [{ "@type": "ListItem", position: 3, name: parent.name, item: `https://primorum.ai/skills/${parent.slug}` }] : []),
    { "@type": "ListItem", position: parent ? 4 : 3, name: skill.name, item: `https://primorum.ai/skills/s/${skill.slug}` },
  ],
};
---

<Base title={title} description={description} reading={true} noindex={!skill.indexable}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <p class="eyebrow">
    <a href="/skills" class="crumb">Skills Directory</a>
    {parent && <> / <a href={`/skills/${parent.slug}`} class="crumb">{parent.name}</a></>}
  </p>

  <h1>{skill.name}</h1>
  <p class="lede">
    An agent skill by
    <a href={skill.authorGithub} target="_blank" rel="noopener">{skill.repo.split("/")[0]}</a>,
    from <a href={`https://github.com/${skill.repo}`} target="_blank" rel="noopener">{skill.repo}</a>.
  </p>

  <blockquote class="skill-desc">
    <p>{skill.description}</p>
    <footer class="mono">
      — from the skill's <a href={skill.rawUrl} target="_blank" rel="noopener">SKILL.md</a>, quoted with attribution
    </footer>
  </blockquote>

  <div class="credit-box">
    <p class="mono install-label">Credit where it's due</p>
    <p>
      This skill is the work of
      <a href={skill.authorGithub} target="_blank" rel="noopener">{skill.repo.split("/")[0]}</a>
      {parent?.official ? " (official vendor skill)" : ""} and lives at
      <a href={skill.githubUrl} target="_blank" rel="noopener">{skill.repo}/{skill.folder}</a>
      ({skill.license}). We index it here so it can be found — if it's useful to you,
      <strong>star the repo, file issues, and contribute upstream</strong>. That's what keeps
      work like this maintained.
    </p>
  </div>

  <dl class="contact-grid">
    <dt>From</dt>
    <dd>
      {parent ? <a href={`/skills/${parent.slug}`}>{parent.name}</a> : skill.repo}
      {parent?.official && " — official vendor skill"}
    </dd>
    <dt>Author</dt>
    <dd><a href={skill.authorGithub} target="_blank" rel="noopener">{skill.repo.split("/")[0]}</a></dd>
    <dt>License</dt>
    <dd>{skill.license}</dd>
    <dt>Source</dt>
    <dd><a href={skill.githubUrl} target="_blank" rel="noopener">{skill.repo}/{skill.folder}</a></dd>
    <dt>SKILL.md</dt>
    <dd><a href={skill.rawUrl} target="_blank" rel="noopener">raw file</a></dd>
  </dl>

  <h2 id="install">How to load this skill</h2>

  <div class="prompt-box">
    <p class="install-label mono">Copy this prompt into your AI agent</p>
    <pre class="install-prompt" id="install-prompt"><code>{installPromptText}</code></pre>
    <button class="copy-prompt mono" id="copy-prompt-btn" type="button">Copy install prompt</button>
  </div>

  <p>
    Or manually: clone <code>{skill.repo}</code> and copy
    <code>{skill.path.replace(/\/SKILL\.md$/, "")}</code> into
    <code>~/.claude/skills/</code> (Claude Code personal scope) or your agent's
    SKILL.md directory. To read it first without installing, open the
    <a href={skill.rawUrl} target="_blank" rel="noopener">raw SKILL.md</a>.
  </p>

  {
    related.length > 0 && (
      <>
        <h2>Related skills</h2>
        <ul>
          {related.map((r) => (
            <li>
              <a href={`/skills/s/${r.slug}`}>{r.name}</a> — {r.description.slice(0, 110)}{r.description.length > 110 ? "…" : ""}
            </li>
          ))}
        </ul>
      </>
    )
  }

  {
    siblings.length > 0 && (
      <>
        <h2>More from {parent?.name || skill.repo}</h2>
        <ul>
          {siblings.map((r) => (
            <li><a href={`/skills/s/${r.slug}`}>{r.name}</a></li>
          ))}
        </ul>
      </>
    )
  }

  <p class="mono back-link"><a href="/skills">&larr; Skills directory</a></p>
</Base>

<style>
  .crumb { text-decoration: none; }
  .back-link { margin-top: 3rem; }
  .skill-desc { margin: 0 0 1.5rem; }
  .skill-desc footer { font-style: normal; color: var(--muted); margin-top: 0.5rem; }
  .credit-box { border: 1px solid var(--rule); border-left: 3px solid var(--accent); padding: 1rem 1.2rem; margin: 0 0 1.5rem; }
  .credit-box p:last-child { margin: 0; }
  .prompt-box { border: 1px solid var(--rule); padding: 1rem 1.2rem 1.2rem; margin: 1.25rem 0 1.75rem; }
  .install-prompt { margin: 0 0 0.9rem; padding: 0.6rem 0.8rem; background: rgba(0,0,0,0.045); overflow-x: auto; font-size: 0.78rem; line-height: 1.5; white-space: pre-wrap; max-height: 16rem; overflow-y: auto; }
  .install-prompt code { font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace; }
  .install-label { color: var(--muted); margin-bottom: 0.4rem; }
  .copy-prompt { font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, Consolas, monospace; font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.45rem 1rem; border: 1px solid var(--rule); background: transparent; color: var(--ink); cursor: pointer; }
  .copy-prompt:hover { border-color: var(--accent); color: var(--accent); }
  .copy-prompt.copied { background: var(--ink); color: var(--bg); border-color: var(--ink); }
</style>

<script>
  const btn = document.getElementById("copy-prompt-btn");
  const pre = document.getElementById("install-prompt");
  function legacyCopy(text: string): boolean {
    const ta = document.createElement("textarea");
    ta.value = text; ta.style.position = "fixed"; ta.style.opacity = "0";
    document.body.appendChild(ta); ta.select();
    let ok = false;
    try { ok = document.execCommand("copy"); } catch {}
    ta.remove(); return ok;
  }
  btn?.addEventListener("click", async () => {
    const text = pre?.textContent?.trim();
    if (!text) return;
    let ok = false;
    try { await navigator.clipboard.writeText(text); ok = true; } catch { ok = legacyCopy(text); }
    const prev = btn.textContent;
    btn.textContent = ok ? "Copied — paste into your AI" : "Copy failed";
    btn.classList.toggle("copied", ok);
    setTimeout(() => { btn.textContent = prev; btn.classList.remove("copied"); }, 2000);
  });
</script>
